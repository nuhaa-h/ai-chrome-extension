{
  "manifest_version": 3,
  "name": "AI Chrome Autocomplete",
  "version": "1.0",
  "description": "AI-powered autocomplete for text fields on any website.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}